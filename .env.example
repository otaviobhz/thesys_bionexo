# Thesys-Bionexo Portal — Environment Variables
# Copie este arquivo para .env e preencha os valores

# Ports
FRONTEND_PORT=7000
BACKEND_PORT=7002
POSTGRES_PORT=7432
REDIS_PORT=7379

# PostgreSQL
POSTGRES_USER=bionexo
POSTGRES_PASSWORD=ALTERAR_SENHA_POSTGRES
POSTGRES_DB=thesys_bionexo

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=ALTERAR_JWT_SECRET
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Backend
DATABASE_URL=postgresql://bionexo:ALTERAR_SENHA_POSTGRES@postgres:5432/thesys_bionexo
NODE_ENV=development

# Bionexo EDI WebService
BIONEXO_AMBIENTE=SANDBOX
BIONEXO_URL_SANDBOX=http://sandbox.bionexo.com.br/ws2/BionexoBean
BIONEXO_URL_PRODUCAO=https://ws.bionexo.com.br/BionexoBean
BIONEXO_WSDL_SANDBOX=http://sandbox.bionexo.com.br/ws2/BionexoBean?wsdl
BIONEXO_WSDL_PRODUCAO=https://ws.bionexo.com.br/BionexoBean?wsdl

# Thesys API
THESYS_BASE_URL=https://thesys.atrpservices.com.br/thesysbi/thesys_bi_api.dll
THESYS_APIKEY_ITENS=ALTERAR_APIKEY
THESYS_APIKEY_PRECOS=ALTERAR_APIKEY
THESYS_APIKEY_HOSPITAIS=ALTERAR_APIKEY
THESYS_APIKEY_COTACAO=ALTERAR_APIKEY
